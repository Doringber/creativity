# qa-agent configuration template.
# Copy to `.env` (already in .gitignore) and fill in your values.

# --- Atlassian (Jira + Confluence) ---
# Site host, no scheme. e.g. yourtenant.atlassian.net
QA_AGENT_ATLASSIAN_SITE=
# Account email used for the API token.
QA_AGENT_ATLASSIAN_EMAIL=
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
QA_AGENT_ATLASSIAN_API_TOKEN=
# Optional: pin the cloud ID. Resolved at runtime from the site if unset.
QA_AGENT_ATLASSIAN_CLOUD_ID=

# --- Jira scope ---
# Comma-separated project keys the agent considers. Leave blank for all visible.
QA_AGENT_JIRA_PROJECTS=
# JQL fragment for the lookback window. ANDed with the project filter.
QA_AGENT_JIRA_WINDOW=updated >= -30d

# --- Confluence scope ---
# Comma-separated space keys. Leave blank to skip Confluence.
QA_AGENT_CONFLUENCE_SPACES=

# --- LLM (used in later commits) ---
# Default backend.  ollama | anthropic
QA_AGENT_LLM_BACKEND=ollama
QA_AGENT_LLM_MODEL=qwen2.5-coder:7b
# Required only if QA_AGENT_LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=
