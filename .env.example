# israel-transit-mcp configuration template.
# Copy to `.env` (gitignored) and fill in values.

# --- Driving ETA (required for plan_route in driving mode) ---
# https://console.cloud.google.com -> enable Routes API -> create API key
GOOGLE_MAPS_API_KEY=

# --- Storage ---
# Where the SQLite RAG db + cached GTFS bundle live. Default: ~/.israel-transit-mcp
ISRAEL_TRANSIT_STORE_DIR=

# --- Anomaly thresholds (optional, sensible defaults) ---
# Minutes-over-p75 that count as anomalous.
ANOMALY_THRESHOLD_MINUTES=5
# Minimum sample size in a (route, weekday, hour) bucket before we trust the baseline.
BASELINE_MIN_SAMPLES=5

# --- News RSS ---
# Comma-separated subset to enable. Leave blank for the default set.
NEWS_FEEDS=
# How many recent items per feed to keep cached.
NEWS_ITEMS_PER_FEED=50
